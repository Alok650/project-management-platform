{
  "name": "project-management-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/database.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/database.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/database.ts",
    "seed": "ts-node -r dotenv/config src/seeds/seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration",
    "test:unit": "jest --testPathPattern=unit"
  },
  "dependencies": {
    "koa": "^2.15.3",
    "@koa/router": "^12.0.1",
    "@koa/cors": "^5.0.0",
    "koa-bodyparser": "^4.4.1",
    "koa-helmet": "^7.0.2",
    "typeorm": "^0.3.20",
    "mysql2": "^3.11.0",
    "ioredis": "^5.4.1",
    "@aws-sdk/client-sqs": "^3.600.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "pino": "^9.4.0",
    "prom-client": "^15.1.3",
    "ws": "^8.18.0",
    "lodash": "^4.17.21",
    "p-limit": "^6.1.0",
    "uuid": "^10.0.0",
    "swagger-jsdoc": "^6.2.8",
    "koa2-swagger-ui": "^5.10.0",
    "dayjs": "^1.11.13",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/koa": "^2.15.0",
    "@types/koa__router": "^12.0.4",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa__cors": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/ws": "^8.5.13",
    "@types/lodash": "^4.17.12",
    "@types/uuid": "^10.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "pino-pretty": "^11.2.2"
  }
}
